import java.util.Scanner;

public class PrimeChecker {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        System.out.print("Enter a number: ");
        int number = scanner.nextInt();

        if (isPrime(number)) {
            System.out.println(number + " is a prime number.");
        } else {
            System.out.println(number + " is not a prime number.");
        }
        scanner.close();
    }

    public static boolean isPrime(int n) {
        // 1. Handle edge cases
        if (n <= 1) return false;
        if (n <= 3) return true;

        // 2. Optimization: Check for 2 and 3 to skip even numbers and multiples of 3
        if (n % 2 == 0 || n % 3 == 0) return false;

        // 3. Main Loop: Iterate up to √n
        // We use (i * i <= n) as it's faster than calling Math.sqrt(n)
        // We increment by 6 to check numbers in the form 6k ± 1
        for (int i = 5; i * i <= n; i += 6) {
            if (n % i == 0 || n % (i + 2) == 0) {
                return false;
            }
        }

        return true;
    }
}
